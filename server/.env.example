PORT=4000
JWT_SECRET=change-this-to-a-long-random-string-in-production
CLIENT_ORIGIN=http://localhost:5173

# Opcional: solo en producción, si montas un volumen persistente (ej. Railway
# Volumes). Déjalas vacías/comentadas en desarrollo local.
# DATA_DIR=/data
# UPLOADS_DIR=/data/uploads/cvs

# Opcional: límites de intentos por IP. En una feria muchos comparten la misma
# IP (wifi), así que ya vienen ALTOS por defecto (login 200/15min, registro
# 500/hora). Súbelos si hiciera falta (o pon un número enorme para desactivar).
# LOGIN_RATE_MAX=200
# REGISTER_RATE_MAX=500

# Opcional: respaldo con IA para coincidencias de habilidades que la comparación
# algorítmica no capte (sinónimos no obvios). DESACTIVADO por defecto. Para
# activarlo, define las tres variables. Tiene costo por uso y requiere red.
# AI_MATCH=1
# ANTHROPIC_API_KEY=sk-ant-...
# AI_MATCH_MODEL=claude-haiku-4-5-20251001
